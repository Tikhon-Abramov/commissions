import styled from 'styled-components';
import type { ChangeEvent } from 'react';
import type { CommissionCard, CommissionForm } from '../../types/commission';

type Props = {
  open: boolean;
  card: CommissionCard | null;
  form: CommissionForm | null;
  onClose: () => void;
  onSave: () => void;
  onChange: (patch: Partial<CommissionForm>) => void;
};

