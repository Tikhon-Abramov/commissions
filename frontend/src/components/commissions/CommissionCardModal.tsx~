  }
`;

const Item = styled.div`
  border-radius: 14px;
  background: ${({ theme }) => theme.colors.surfaceAlt};
  padding: 12px;
`;

const Label = styled.div`
  font-size: 12px;
  color: ${({ theme }) => theme.colors.muted};
  margin-bottom: 6px;
`;

const Value = styled.div`
  font-size: 14px;
  line-height: 1.35;
  word-break: break-word;
`;

const Table = styled.table`
  width: 100%;
  border-collapse: collapse;
`;

const TH = styled.th`
  text-align: left;
  font-size: 12px;
  color: ${({ theme }) => theme.colors.muted};
  padding: 8px 6px;
  border-bottom: 1px solid ${({ theme }) => theme.colors.border};
`;

const TD = styled.td`
  font-size: 13px;
  padding: 10px 6px;
  border-bottom: 1px solid ${({ theme }) => theme.colors.border};
`;

const FormGrid = styled.div`
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;

  @media (max-width: 820px) {
    grid-template-columns: 1fr;
  }
`;

const Field = styled.label`
  display: grid;
  gap: 6px;
  font-size: 13px;
`;

const Input = styled.input`
  height: 42px;
  border-radius: 12px;
  border: 1px solid ${({ theme }) => theme.colors.border};
  background: ${({ theme }) => theme.colors.background};
  color: ${({ theme }) => theme.colors.text};
  padding: 0 12px;
`;

const Select = styled.select`
  height: 42px;
  border-radius: 12px;
  border: 1px solid ${({ theme }) => theme.colors.border};
  background: ${({ theme }) => theme.colors.background};
  color: ${({ theme }) => theme.colors.text};
  padding: 0 12px;
`;

const Textarea = styled.textarea`
  min-height: 96px;
  border-radius: 12px;
  border: 1px solid ${({ theme }) => theme.colors.border};
  background: ${({ theme }) => theme.colors.background};
  color: ${({ theme }) => theme.colors.text};
  padding: 12px;
  resize: vertical;
`;

const Footer = styled.div`
  position: sticky;
  bottom: 0;
  background: ${({ theme }) => theme.colors.surface};
  border-top: 1px solid ${({ theme }) => theme.colors.border};
  padding: 16px 24px;
  display: flex;
  justify-content: flex-end;
  gap: 12px;
`;

const Button = styled.button<{ $primary?: boolean }>`
  height: 42px;
  padding: 0 16px;
  border-radius: 12px;
  cursor: pointer;
  border: ${({ $primary, theme }) => ($primary ? 'none' : `1px solid ${theme.colors.border}`)};
  background: ${({ $primary, theme }) => ($primary ? theme.colors.primary : theme.colors.surface)};
  color: ${({ $primary, theme }) => ($primary ? '#fff' : theme.colors.text)};
`;

const formatAmount = (value?: number | null) => {
  if (value === null || value === undefined) return '—';
  return `${value.toLocaleString('ru-RU')} ₽`;
};

const formatDate = (value?: string) => {
  if (!value) return '—';
  const [year, month, day] = value.split('-');
  return `${day}.${month}.${year}`;
};

export function CommissionCardModal({
                                      open,
                                      card,
                                      form,
                                      onClose,
                                      onSave,
                                      onChange,
                                    }: Props) {
  if (!card || !form) {
    return <Overlay $open={false} />;
  }

  const handleFileChange = (event: ChangeEvent<HTMLInputElement>) => {
    const file = event.target.files?.[0];
    if (!file) return;
    onChange({ protocolFileName: file.name });
  };

  return (
      <Overlay $open={open}>
        <Panel>
          <Header>
            <TitleWrap>
              <Title>Просмотр ИНН</Title>
              <Subtitle>
                {card.inn} · {card.name}
              </Subtitle>
            </TitleWrap>

            <Button type="button" onClick={onClose}>
              Закрыть
            </Button>
          </Header>

          <Body>
            <Section>
              <SectionTitle>Основная информация</SectionTitle>
              <DenseGrid>
                <Item>
                  <Label>ИНН</Label>
                  <Value>{card.inn}</Value>
                </Item>
                <Item>
                  <Label>Код НО</Label>
                  <Value>{card.kno || '—'}</Value>
                </Item>
                <Item>
                  <Label>ОКТМО</Label>
                  <Value>{card.oktmo || '—'}</Value>
                </Item>
                <Item>
                  <Label>Сотрудники с задолженностью</Label>
                  <Value>{card.employeeDebtorsCount ?? '—'}</Value>
                </Item>
                <Item>
                  <Label>Кол-во объектов недвижимости</Label>
                  <Value>{card.realEstateObjectsCount ?? '—'}</Value>
                </Item>
                <Item>
                  <Label>Кол-во земельных участков</Label>
                  <Value>{card.landPlotsCount ?? '—'}</Value>
                </Item>
                <Item>
                  <Label>Кол-во транспортных средств</Label>
                  <Value>{card.transportCount ?? '—'}</Value>
                </Item>
                <Item>
                  <Label>ОКВЭД</Label>
                  <Value>{card.okved || '—'}</Value>
                </Item>
              </DenseGrid>

              <InfoGrid style={{ marginTop: 12 }}>
                <Item>
                  <Label>Адрес</Label>
                  <Value>{card.address || '—'}</Value>
                </Item>
                <Item>
                  <Label>Руководитель / телефон</Label>
                  <Value>
                    {card.director || '—'}
                    <br />
                    {card.phone || '—'}
                  </Value>
                </Item>
              </InfoGrid>
            </Section>

            <Section>
              <SectionTitle>Выручка</SectionTitle>
              <Table>
                <thead>
                <tr>
                  {card.revenueByYear?.map((item) => <TH key={item.year}>{item.year}</TH>)}
                </tr>
                </thead>
                <tbody>
                <tr>
                  {card.revenueByYear?.map((item) => (
                      <TD key={item.year}>{formatAmount(item.value)}</TD>
                  ))}
                </tr>
                </tbody>
              </Table>
            </Section>

            <Section>
              <SectionTitle>Среднесписочная численность</SectionTitle>
              <Table>
                <thead>
                <tr>
                  {card.headcountByYear?.map((item) => <TH key={item.year}>{item.year}</TH>)}
                </tr>
                </thead>
                <tbody>
                <tr>
                  {card.headcountByYear?.map((item) => (
                      <TD key={item.year}>{item.value ?? '—'}</TD>
                  ))}
                </tr>
                </tbody>
              </Table>
            </Section>

            <Section>
              <SectionTitle>Сальдо ЕНС и задолженность перед регионом</SectionTitle>
              <Table>
                <thead>
                <tr>
                  <TH>Дата</TH>
                  <TH>Сальдо ЕНС</TH>
                  <TH>Задолженность перед регионом</TH>
                </tr>
                </thead>
                <tbody>
                {card.balances.map((item) => (
                    <tr key={item.date}>
                      <TD>{formatDate(item.date)}</TD>
                      <TD>{formatAmount(item.amount)}</TD>
                      <TD>{formatAmount(item.debtToRegion)}</TD>
                    </tr>
                ))}
                </tbody>
              </Table>
            </Section>

            <Section>
              <SectionTitle>Данные за предыдущие периоды</SectionTitle>
              <Table>
                <thead>
                <tr>
                  <TH>Дата</TH>
                  <TH>Сальдо ЕНС</TH>
                  <TH>Задолженность перед регионом</TH>
                </tr>
                </thead>
                <tbody>
                {card.previousPeriods?.map((item) => (
                    <tr key={item.date}>
                      <TD>{formatDate(item.date)}</TD>
                      <TD>{formatAmount(item.ensBalance)}</TD>
                      <TD>{formatAmount(item.regionalDebt)}</TD>
                    </tr>
                ))}

                {!card.previousPeriods?.length ? (
                    <tr>
                      <TD colSpan={3}>Нет данных</TD>
                    </tr>
                ) : null}
                </tbody>
              </Table>
            </Section>

            <Section>
              <SectionTitle>Меры взыскания</SectionTitle>
              <DenseGrid>
                <Item>
                  <Label>Наличие требования</Label>
                  <Value>{card.enforcement?.requirementExists ? 'Да' : 'Нет'}</Value>
                </Item>
                <Item>
                  <Label>Наличие решения 46 ст.</Label>
                  <Value>{card.enforcement?.decision46Exists ? 'Да' : 'Нет'}</Value>
                </Item>
                <Item>
                  <Label>Кол-во постановлений 47 ст.</Label>
                  <Value>{card.enforcement?.постановления47Count ?? '0'}</Value>
                </Item>
                <Item>
                  <Label>Остаток задолженности по 47 ст.</Label>
                  <Value>{formatAmount(card.enforcement?.debt47Amount)}</Value>
                </Item>
                <Item>
                  <Label>Кол-во ЗВСП по 48 ст.</Label>
                  <Value>{card.enforcement?.zvsp48Count ?? '0'}</Value>
                </Item>
                <Item>
                  <Label>Остаток задолженности по ЗВСП</Label>
                  <Value>{formatAmount(card.enforcement?.zvspDebtAmount)}</Value>
                </Item>
              </DenseGrid>
            </Section>

            <Section>
              <SectionTitle>Проведение комиссии</SectionTitle>
              <FormGrid>
                <Field>
                  Статус комиссии
                  <Select
                      value={form.commissionStatus}
                      onChange={(e) => onChange({ commissionStatus: e.target.value })}
                  >
                    <option value="">--Выберите статус комиссии--</option>
                    <option value="Не требуется проведение комиссии">Не требуется проведение комиссии</option>
                    <option value="Комиссия проведена">Комиссия проведена</option>
                    <option value="Неявка на комиссию">Неявка на комиссию</option>
                  </Select>
                </Field>

                <Field>
                  Результат взаимодействия с НП
                  <Select
                      value={form.interactionStatus}
                      onChange={(e) => onChange({ interactionStatus: e.target.value })}
                  >
                    <option value="">--Выберите статус--</option>
                    <option value="Долг погашен">Долг погашен</option>
                    <option value="Погасит в течение месяца">Погасит в течение месяца</option>
                    <option value="Погасит в течение квартала">Погасит в течение квартала</option>
                    <option value="Согласие на оплату после поступления денежных средств от дебитора">
                      Согласие на оплату после поступления денежных средств от дебитора
                    </option>
                    <option value="Представлена уточненная НД с суммой, превышающей начисления">
                      Представлена уточненная НД с суммой, превышающей начисления
                    </option>
                    <option value="Рассматривается вопрос о предоставлении отсрочки/рассрочки">
                      Рассматривается вопрос о предоставлении отсрочки/рассрочки
                    </option>
                    <option value="Есть решение об отложении мер взыскания">
                      Есть решение об отложении мер взыскания
                    </option>
                    <option value='НП "На особом контроле"'>НП "На особом контроле"</option>
                    <option value='Клиент "Площадки реструктуризации долга"'>
                      Клиент "Площадки реструктуризации долга"
                    </option>
                    <option value="Задолженность оспаривается">Задолженность оспаривается</option>
                    <option value="Отказ от погашения долга">Отказ от погашения долга</option>
                    <option value="Долг подлежит списанию">Долг подлежит списанию</option>
                    <option value="НП в отчетном квартале - мигрировал">
                      НП в отчетном квартале - мигрировал
                    </option>
                    <option value="НП в отчетном квартале - ликвидирован">
                      НП в отчетном квартале - ликвидирован
                    </option>
                    <option value="НП в отчетном квартале - исключен в связи со смертью">
                      НП в отчетном квартале - исключен в связи со смертью
                    </option>
                    <option value="НП в отчетном квартале - гражданин признан банкротом/реализация имущества">
                      НП в отчетном квартале - гражданин признан банкротом/реализация имущества
                    </option>
                    <option value="НП в отчетном квартале - конкурсное производство">
                      НП в отчетном квартале - конкурсное производство
                    </option>
                  </Select>
                </Field>

                <Field>
                  Дата проведения комиссии
                  <Input
                      type="date"
                      value={form.commissionDate}
                      onChange={(e) => onChange({ commissionDate: e.target.value })}
                  />
                </Field>

                <Field>
                  Файл протокола
                  <Input type="file" onChange={handleFileChange} />
                </Field>
              </FormGrid>

              <Field style={{ marginTop: 14 }}>
                Меры воздействия со стороны региональных / местных органов власти, прокуратуры, правоохранительных органов, ФССП и ФОИВ
                <Textarea
                    value={form.influenceMeasures ?? ''}
                    onChange={(e) => onChange({ influenceMeasures: e.target.value })}
                />
              </Field>

              <Field style={{ marginTop: 14 }}>
                Участие в комиссии представителей органов государственной власти (ОГВ) и органов местного самоуправления (ОМСУ)
                <Textarea
                    value={form.authorityParticipation ?? ''}
                    onChange={(e) => onChange({ authorityParticipation: e.target.value })}
                />
              </Field>

              <Field style={{ marginTop: 14 }}>
                Примечание к комиссии
                <Textarea
                    value={form.comment}
                    onChange={(e) => onChange({ comment: e.target.value })}
                />
              </Field>

              <Item style={{ marginTop: 14 }}>
                <Label>Текущий протокол</Label>
                <Value>{form.protocolFileName || 'Файл не прикреплен'}</Value>
              </Item>
            </Section>

            <Section>
              <SectionTitle>История изменений</SectionTitle>
              <Table>
                <thead>
                <tr>
                  <TH>Дата</TH>
                  <TH>Действие</TH>
                  <TH>Автор</TH>
                </tr>
                </thead>
                <tbody>
                {card.history.map((item, index) => (
                    <tr key={`${item.date}-${index}`}>
                      <TD>{formatDate(item.date)}</TD>
                      <TD>{item.action}</TD>
                      <TD>{item.author}</TD>
                    </tr>
                ))}
                </tbody>
              </Table>
            </Section>
          </Body>

          <Footer>
            <Button type="button" onClick={onClose}>
              Закрыть
            </Button>
            <Button type="button" $primary onClick={onSave}>
              Сохранить
            </Button>
          </Footer>
        </Panel>
      </Overlay>
  );
}