const formatDateTime = (value: string) =>
    new Date(value).toLocaleString('ru-RU', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
    });

const regionNameFromCode = (code?: string | null) => {
    if (code === '77') return '77 — Москва';
    if (code === '78') return '78 — Санкт-Петербург';
    if (code === '50') return '50 — Московская область';
    return code || 'Регион пользователя';
};

const formatAttachment = (file: File): FeedbackAttachment => ({
    id: `att-${Date.now()}`,
    name: file.name,
    type: file.type || 'application/octet-stream',
    size: file.size,
    url: URL.createObjectURL(file),
});

type TicketsResponse = {
    success: true;
    data: FeedbackTicket[];
};

type MessagesResponse = {
    success: true;
    data: FeedbackMessage[];
};

type CreateTicketResponse = {
    success: true;
    ticketId: string;
};

export function FeedbackPage() {
    const dispatch = useAppDispatch();
    const { isAdmin, region } = useAppSelector((state) => state.auth);
    const {
        tickets,
        messages,
        selectedTicketId,
        statusFilter,
        isCreateModalOpen,
        draftTemplate,
        replyText,
        isLoadingTickets,
        isLoadingMessages,
        isSubmitting,
        error,
    } = useAppSelector((state) => state.feedback);

    const [isDragging, setIsDragging] = useState(false);

    const currentRegionName = regionNameFromCode(region);

    const loadTickets = async () => {
        dispatch(setFeedbackTicketsLoading(true));
        dispatch(setFeedbackError(''));

        try {
            const response = await apiRequest<TicketsResponse>('/feedback/tickets');
            dispatch(setFeedbackTickets(response.data));
        } catch (err) {
            dispatch(setFeedbackError(err instanceof Error ? err.message : 'Ошибка загрузки обращений'));
        } finally {
            dispatch(setFeedbackTicketsLoading(false));
        }
    };

    const loadMessages = async (ticketId: string) => {
        dispatch(setFeedbackMessagesLoading(true));
        dispatch(setFeedbackError(''));

        try {
            const response = await apiRequest<MessagesResponse>(`/feedback/tickets/${ticketId}/messages`);
            dispatch(setFeedbackMessages(response.data));
        } catch (err) {
            dispatch(setFeedbackError(err instanceof Error ? err.message : 'Ошибка загрузки сообщений'));
        } finally {
            dispatch(setFeedbackMessagesLoading(false));
        }
    };

    useEffect(() => {
        loadTickets();
    }, []);

    useEffect(() => {
        if (!selectedTicketId) {
            dispatch(setFeedbackMessages([]));
            return;
        }

        loadMessages(selectedTicketId);
    }, [selectedTicketId]);

    const visibleTickets = useMemo(() => {
        const filtered =
            statusFilter === 'all'
                ? tickets
                : tickets.filter((ticket) => ticket.status === statusFilter);

        return [...filtered].sort(
            (a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime(),
        );
    }, [statusFilter, tickets]);

    const selectedTicket =
        visibleTickets.find((ticket) => ticket.id === selectedTicketId) ??
        tickets.find((ticket) => ticket.id === selectedTicketId) ??
        null;

    const selectedMessages = useMemo(() => {
        return [...messages].sort(
            (a, b) => new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime(),
        );
    }, [messages]);

    const stats = useMemo(() => {
        return {
            total: tickets.length,
            new: tickets.filter((ticket) => ticket.status === 'new').length,
            in_progress: tickets.filter((ticket) => ticket.status === 'in_progress').length,
            resolved: tickets.filter((ticket) => ticket.status === 'resolved').length,
            closed: tickets.filter((ticket) => ticket.status === 'closed').length,
        };
    }, [tickets]);

    const unreadCount = useMemo(() => {
        return tickets.reduce(
            (acc, ticket) => acc + (isAdmin ? ticket.unreadForAdmin : ticket.unreadForUser),
            0,
        );
    }, [isAdmin, tickets]);

    const handleSendReply = async () => {
        if (!selectedTicket || isFinalStatus(selectedTicket.status) || !replyText.trim()) return;

        dispatch(setFeedbackSubmitting(true));
        dispatch(setFeedbackError(''));

        try {
            await apiRequest(`/feedback/tickets/${selectedTicket.id}/messages`, {
                method: 'POST',
                json: {
                    text: replyText.trim(),
                },
            });

            dispatch(sendFeedbackReplySuccess());
            await loadTickets();
            await loadMessages(selectedTicket.id);
        } catch (err) {
            dispatch(setFeedbackError(err instanceof Error ? err.message : 'Ошибка отправки сообщения'));
        } finally {
            dispatch(setFeedbackSubmitting(false));
        }
    };

    const handleCreateTicket = async () => {
        if (!draftTemplate.text.trim()) return;

        dispatch(setFeedbackSubmitting(true));
        dispatch(setFeedbackError(''));

        try {
            const response = await apiRequest<CreateTicketResponse>('/feedback/tickets', {
                method: 'POST',
                json: {
                    text: draftTemplate.text.trim(),
                },
            });

            dispatch(createFeedbackTicketSuccess({ ticketId: response.ticketId }));
            await loadTickets();
            dispatch(selectFeedbackTicket(response.ticketId));
            await loadMessages(response.ticketId);
        } catch (err) {
            dispatch(setFeedbackError(err instanceof Error ? err.message : 'Ошибка создания обращения'));
        } finally {
            dispatch(setFeedbackSubmitting(false));
        }
    };

    const handleStatusChange = async (status: TicketStatus) => {
        if (!selectedTicket) return;

        dispatch(setFeedbackSubmitting(true));
        dispatch(setFeedbackError(''));

        try {
            await apiRequest(`/feedback/tickets/${selectedTicket.id}/status`, {
                method: 'PATCH',
                json: {
                    status,
                },
            });

            dispatch(
                updateFeedbackTicketStatusLocal({
                    ticketId: selectedTicket.id,
                    status,
                }),
            );

            await loadTickets();
        } catch (err) {
            dispatch(setFeedbackError(err instanceof Error ? err.message : 'Ошибка обновления статуса'));
        } finally {
            dispatch(setFeedbackSubmitting(false));
        }
    };

    const applyFile = (file?: File | null) => {
        if (!file) {
            dispatch(setFeedbackDraftAttachment(null));
            return;
        }

        dispatch(setFeedbackDraftAttachment(formatAttachment(file)));
    };

    return (
        <Root>
            <PageWrap>
                <HeaderBlock>
                    <PageHeader
                        title="Обратная связь"
                        description={`Обращения и переписка с поддержкой.${unreadCount ? ` Непрочитано: ${unreadCount}.` : ''}`}
                    />
                </HeaderBlock>

                <Toolbar>
                    <StatsRow>
                        <StatChip
                            type="button"
                            $active={statusFilter === 'all'}
                            onClick={() => dispatch(setFeedbackStatusFilter('all'))}
                        >
                            Всего: {stats.total}
                        </StatChip>
                        <StatChip
                            type="button"
                            $active={statusFilter === 'new'}
                            onClick={() => dispatch(setFeedbackStatusFilter('new'))}
                        >
                            Новых: {stats.new}
                        </StatChip>
                        <StatChip
                            type="button"
                            $active={statusFilter === 'in_progress'}
                            onClick={() => dispatch(setFeedbackStatusFilter('in_progress'))}
                        >
                            В работе: {stats.in_progress}
                        </StatChip>
                        <StatChip
                            type="button"
                            $active={statusFilter === 'resolved'}
                            onClick={() => dispatch(setFeedbackStatusFilter('resolved'))}
                        >
                            Решённых: {stats.resolved}
                        </StatChip>
                        <StatChip
                            type="button"
                            $active={statusFilter === 'closed'}
                            onClick={() => dispatch(setFeedbackStatusFilter('closed'))}
                        >
                            Закрытых: {stats.closed}
                        </StatChip>
                    </StatsRow>

                    <Controls>
                        <Select
                            value={statusFilter}
                            onChange={(e) =>
                                dispatch(setFeedbackStatusFilter(e.target.value as 'all' | TicketStatus))
                            }
                        >
                            <option value="all">Все статусы</option>
                            {feedbackStatuses.map((status) => (
                                <option key={status.key} value={status.key}>
                                    {status.label}
                                </option>
                            ))}
                        </Select>

                        {!isAdmin ? (
                            <PrimaryButton type="button" onClick={() => dispatch(openCreateFeedbackModal())}>
                                Новое обращение
                            </PrimaryButton>
                        ) : null}
                    </Controls>
                </Toolbar>

                {error ? <ErrorText>{error}</ErrorText> : null}

                <Layout>
                    <Sidebar>
                        {isLoadingTickets ? (
                            <EmptyBox>Загрузка обращений...</EmptyBox>
                        ) : !visibleTickets.length ? (
                            <EmptyBox>Обращения не найдены.</EmptyBox>
                        ) : (
                            <TicketList>
                                {visibleTickets.map((ticket) => {
                                    const unread = isAdmin ? ticket.unreadForAdmin : ticket.unreadForUser;

                                    return (
                                        <TicketItem
                                            key={ticket.id}
                                            $active={ticket.id === selectedTicket?.id}
                                            onClick={() => dispatch(selectFeedbackTicket(ticket.id))}
                                        >
                                            <TicketTop>
                                                <TicketSubject>{ticket.subject}</TicketSubject>
                                                <StatusBadge $status={ticket.status}>
                                                    {statusLabels[ticket.status]}
                                                </StatusBadge>
                                            </TicketTop>

                                            <TicketMeta>
                                                {ticket.regionName || ticket.authorFullName || currentRegionName}
                                                <br />
                                                {formatDateTime(ticket.updatedAt)}
                                            </TicketMeta>

                                            {unread > 0 ? (
                                                <div style={{ marginTop: 8 }}>
                                                    <UnreadDot>{unread}</UnreadDot>
                                                </div>
                                            ) : null}
                                        </TicketItem>
                                    );
                                })}
                            </TicketList>
                        )}
                    </Sidebar>

                    <ChatCard>
                        {!selectedTicket ? (
                            <EmptyBox>Выберите обращение слева или создайте новое.</EmptyBox>
                        ) : (
                            <>
                                <ChatHeader>
                                    <div>
                                        <ChatTitle>{selectedTicket.subject}</ChatTitle>
                                        <ChatSubtitle>
                                            {selectedTicket.regionName || selectedTicket.authorFullName || currentRegionName} ·{' '}
                                            {statusLabels[selectedTicket.status]}
                                        </ChatSubtitle>
                                    </div>

                                    <HeaderActions>
                                        {isAdmin ? (
                                            <>
                                                {selectedTicket.status === 'new' ? (
                                                    <SecondaryButton
                                                        type="button"
                                                        onClick={() => handleStatusChange('in_progress')}
                                                        disabled={isSubmitting}
                                                    >
                                                        В работу
                                                    </SecondaryButton>
                                                ) : null}

                                                {selectedTicket.status === 'new' || selectedTicket.status === 'in_progress' ? (
                                                    <>
                                                        <SecondaryButton
                                                            type="button"
                                                            onClick={() => handleStatusChange('resolved')}
                                                            disabled={isSubmitting}
                                                        >
                                                            Решён
                                                        </SecondaryButton>
                                                        <SecondaryButton
                                                            type="button"
                                                            onClick={() => handleStatusChange('closed')}
                                                            disabled={isSubmitting}
                                                        >
                                                            Закрыт
                                                        </SecondaryButton>
                                                    </>
                                                ) : null}
                                            </>
                                        ) : !isFinalStatus(selectedTicket.status) ? (
                                            <>
                                                <SecondaryButton
                                                    type="button"
                                                    onClick={() => handleStatusChange('resolved')}
                                                    disabled={isSubmitting}
                                                >
                                                    Отметить решённым
                                                </SecondaryButton>
                                                <SecondaryButton
                                                    type="button"
                                                    onClick={() => handleStatusChange('closed')}
                                                    disabled={isSubmitting}
                                                >
                                                    Закрыть
                                                </SecondaryButton>
                                            </>
                                        ) : null}
                                    </HeaderActions>
                                </ChatHeader>

                                <Messages>
                                    {isLoadingMessages ? (
                                        <EmptyBox>Загрузка сообщений...</EmptyBox>
                                    ) : !selectedMessages.length ? (
                                        <EmptyBox>Сообщений пока нет.</EmptyBox>
                                    ) : (
                                        selectedMessages.map((message) => {
                                            const mine =
                                                (isAdmin && message.authorRole === 'admin') ||
                                                (!isAdmin && message.authorRole === 'user');

                                            return (
                                                <MessageBubble key={message.id} $mine={mine}>
                                                    <MessageAuthor>{message.authorName}</MessageAuthor>
                                                    <div>{message.text}</div>
                                                    {message.attachment ? (
                                                        <MessageAttachment
                                                            href={message.attachment.url}
                                                            download={message.attachment.name}
                                                            target="_blank"
                                                            rel="noreferrer"
                                                        >
                                                            📎 Скачать: {message.attachment.name}
                                                        </MessageAttachment>
                                                    ) : null}
                                                    <MessageTime>{formatDateTime(message.createdAt)}</MessageTime>
                                                </MessageBubble>
                                            );
                                        })
                                    )}
                                </Messages>

                                <ReplyBox>
                                    <Textarea
                                        value={replyText}
                                        onChange={(e) => dispatch(setFeedbackReplyText(e.target.value))}
                                        placeholder={
                                            isFinalStatus(selectedTicket.status)
                                                ? 'Обращение завершено. Отправка сообщений недоступна.'
                                                : 'Введите сообщение...'
                                        }
                                        disabled={isFinalStatus(selectedTicket.status) || isSubmitting}
                                    />

                                    <ReplyActions>
                                        <div />
                                        <PrimaryButton
                                            type="button"
                                            onClick={handleSendReply}
                                            disabled={isFinalStatus(selectedTicket.status) || isSubmitting}
                                        >
                                            {isSubmitting ? 'Отправка...' : 'Отправить'}
                                        </PrimaryButton>
                                    </ReplyActions>
                                </ReplyBox>
                            </>
                        )}
                    </ChatCard>
                </Layout>

                {isCreateModalOpen ? (
                    <Overlay onClick={() => dispatch(closeCreateFeedbackModal())}>
                        <Modal onClick={(e) => e.stopPropagation()}>
                            <ModalHeader>Новое обращение</ModalHeader>

                            <ModalBody>
                                <Field>
                                    Прикрепить фото или файл
                                    <Dropzone
                                        $dragging={isDragging}
                                        onDragOver={(e) => {
                                            e.preventDefault();
                                            setIsDragging(true);
                                        }}
                                        onDragLeave={() => setIsDragging(false)}
                                        onDrop={(e) => {
                                            e.preventDefault();
                                            setIsDragging(false);
                                            applyFile(e.dataTransfer.files?.[0] ?? null);
                                        }}
                                    >
                                        <div>
                                            <div>Перетащите файл сюда или нажмите для выбора</div>
                                            {draftTemplate.attachment ? (
                                                <AttachmentMeta>📎 {draftTemplate.attachment.name}</AttachmentMeta>
                                            ) : (
                                                <AttachmentMeta>Вложение необязательно</AttachmentMeta>
                                            )}
                                        </div>

                                        <HiddenInput
                                            type="file"
                                            onChange={(e) => applyFile(e.target.files?.[0] ?? null)}
                                        />
                                    </Dropzone>
                                </Field>

                                <Field>
                                    Текст обращения
                                    <Textarea
                                        value={draftTemplate.text}
                                        onChange={(e) => dispatch(updateFeedbackDraft({ text: e.target.value }))}
                                    />
                                </Field>
                            </ModalBody>

                            <ModalFooter>
                                <SecondaryButton type="button" onClick={() => dispatch(closeCreateFeedbackModal())}>
                                    Отмена
                                </SecondaryButton>
                                <PrimaryButton type="button" onClick={handleCreateTicket} disabled={isSubmitting}>
                                    {isSubmitting ? 'Отправка...' : 'Отправить обращение'}
                                </PrimaryButton>
                            </ModalFooter>
                        </Modal>
                    </Overlay>
                ) : null}
            </PageWrap>
        </Root>
    );
}