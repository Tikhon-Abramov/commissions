const formatAmount = (value: number) => `${value.toLocaleString('ru-RU')} ₽`;

const formatPercent = (employeesCount: number, debtorsCount: number) => {
    if (!employeesCount) return '0 %';
    return `${((debtorsCount / employeesCount) * 100).toFixed(1).replace('.', ',')} %`;
};

const formatDateLabel = (value: string) => {
    const [year, month, day] = value.split('-');
    return `${day}.${month}.${year}`;
};

const getLatestAvailableDate = (items: Array<{ date: string }>) => {
    const dates = Array.from(new Set(items.map((item) => item.date))).sort((a, b) => b.localeCompare(a));
    return dates[0] ?? '';
};

export function SecondLevelDebtPage() {
    const dispatch = useAppDispatch();
    const { filters, moList, taxpayerList, selectedCard, isCardOpen } = useAppSelector(
        (state) => state.secondLevelDebt,
    );
    const { isAdmin, region: userRegion } = useAppSelector((state) => state.auth);
    const [expandedOktmo, setExpandedOktmo] = useState<string | null>(null);

    useEffect(() => {
        dispatch(
            setSecondLevelDebtData({
                moList: secondLevelDebtMoList,
                taxpayerList: secondLevelDebtTaxpayerList,
            }),
        );
    }, [dispatch]);

    const latestDate = useMemo(() => getLatestAvailableDate(moList), [moList]);

    useEffect(() => {
        if (!filters.date && latestDate) {
            dispatch(setSecondLevelDebtFilters({ date: latestDate }));
        }
    }, [dispatch, filters.date, latestDate]);

    const regionScopedMo = useMemo(() => {
        const activeRegion = isAdmin ? filters.region : userRegion ?? '';
        return moList.filter((item) => (!activeRegion ? true : item.region === activeRegion));
    }, [filters.region, isAdmin, moList, userRegion]);

    const regionScopedTaxpayers = useMemo(() => {
        const activeRegion = isAdmin ? filters.region : userRegion ?? '';
        return taxpayerList.filter((item) => (!activeRegion ? true : item.region === activeRegion));
    }, [filters.region, isAdmin, taxpayerList, userRegion]);

    const summarySource = useMemo(() => {
        return regionScopedMo.filter((item) => item.date === filters.date);
    }, [filters.date, regionScopedMo]);

    const summary = useMemo(() => {
        const moCount = new Set(summarySource.map((item) => item.oktmo)).size;
        const enterprises = summarySource.reduce((acc, item) => acc + item.enterprisesCount, 0);
        const employees = summarySource.reduce((acc, item) => acc + item.employeesCount, 0);
        const debtors = summarySource.reduce((acc, item) => acc + item.debtorsCount, 0);
        const debtAmount = summarySource.reduce((acc, item) => acc + item.debtAmount, 0);

        return [
            { label: 'Муниципальных округов', value: moCount.toLocaleString('ru-RU') },
            { label: 'Предприятий', value: enterprises.toLocaleString('ru-RU') },
            { label: 'Сотрудников', value: employees.toLocaleString('ru-RU') },
            { label: 'Должников', value: debtors.toLocaleString('ru-RU') },
            { label: 'Задолженность', value: formatAmount(debtAmount) },
        ];
    }, [summarySource]);

    const moTableData = useMemo(() => {
        let result = regionScopedMo.filter((item) => item.date === filters.date);

        if (filters.budgetType === 'budget') {
            result = result.filter((item) => item.budgetType === 'budget');
        }

        if (filters.budgetType === 'non-budget') {
            result = result.filter((item) => item.budgetType === 'non-budget');
        }

        if (filters.search.trim()) {
            const search = filters.search.trim().toLowerCase();
            result = result.filter(
                (item) =>
                    item.oktmo.toLowerCase().includes(search) ||
                    item.moName.toLowerCase().includes(search),
            );
        }

        return result;
    }, [filters.budgetType, filters.date, filters.search, regionScopedMo]);

    const taxpayersByOktmo = useMemo(() => {
        const map = new Map<string, DebtTaxpayerItem[]>();

        regionScopedTaxpayers
            .filter((item) => item.date === filters.date)
            .forEach((item) => {
                const existing = map.get(item.oktmo) ?? [];
                existing.push(item);
                map.set(item.oktmo, existing);
            });

        return map;
    }, [filters.date, regionScopedTaxpayers]);

    const availableDates = useMemo(() => {
        return Array.from(new Set(regionScopedMo.map((item) => item.date)))
            .sort((a, b) => b.localeCompare(a))
            .map((date) => ({
                value: date,
                label: formatDateLabel(date),
            }));
    }, [regionScopedMo]);

    const filterFields: FilterField[] = [
        ...(isAdmin
            ? [
                {
                    key: 'region',
                    label: 'Регион',
                    type: 'select' as const,
                    value: filters.region,
                    options: [
                        { value: '', label: 'Все регионы' },
                        { value: '77', label: '77 — Москва' },
                        { value: '78', label: '78 — Санкт-Петербург' },
                        { value: '50', label: '50 — Московская область' },
                    ],
                    onChange: (value: string) => {
                        dispatch(setSecondLevelDebtFilters({ region: value }));
                        setExpandedOktmo(null);
                    },
                },
            ]
            : []),
        {
            key: 'date',
            label: 'Дата',
            type: 'select' as const,
            value: filters.date,
            options: availableDates,
            onChange: (value: string) => {
                dispatch(setSecondLevelDebtFilters({ date: value }));
                setExpandedOktmo(null);
            },
        },
        {
            key: 'search',
            label: 'Поиск информации',
            value: filters.search,
            placeholder: 'ОКТМО, МО',
            onChange: (value: string) => {
                dispatch(setSecondLevelDebtFilters({ search: value }));
                setExpandedOktmo(null);
            },
        },
        {
            key: 'budgetType',
            label: 'Тип организаций',
            type: 'select' as const,
            value: filters.budgetType,
            options: [
                { value: 'all', label: 'Все организации' },
                { value: 'budget', label: 'Только бюджетные организации' },
                { value: 'non-budget', label: 'Только небюджетные организации' },
            ],
            onChange: (value: string) => {
                dispatch(setSecondLevelDebtFilters({ budgetType: value as 'all' | 'budget' | 'non-budget' }));
                setExpandedOktmo(null);
            },
        },
    ];

    const handleToggleMo = (oktmo: string) => {
        setExpandedOktmo((prev) => (prev === oktmo ? null : oktmo));
    };

    const handleDownloadStats = () => {
        console.log('Скачать статистику', {
            role: isAdmin ? 'admin' : 'user',
            region: isAdmin ? filters.region || 'all' : userRegion,
            date: filters.date,
        });
    };

    const handleDownloadDetails = () => {
        console.log('Скачать детализацию', {
            role: isAdmin ? 'admin' : 'user',
            region: isAdmin ? filters.region || 'all' : userRegion,
            date: filters.date,
        });
    };

    return (
        <>
            <PageHeader
                title="Долг второго уровня"
                description="Сводка по региону и единая раскрывающаяся таблица по МО и налогоплательщикам."
            />

            <Toolbar>
                <Note>
                    По умолчанию загружается крайняя доступная дата. Налогоплательщики раскрываются внутри строки МО.
                </Note>

                <ToolbarActions>
                    <ActionButton type="button" onClick={handleDownloadStats}>
                        Скачать статистику
                    </ActionButton>
                    <ActionButton type="button" onClick={handleDownloadDetails}>
                        Скачать детализацию
                    </ActionButton>
                </ToolbarActions>
            </Toolbar>

            <SummaryCard>
                <SummaryTitle>
                    Сводная информация по региону{filters.date ? ` на ${formatDateLabel(filters.date)}` : ''}
                </SummaryTitle>
                <SummaryGrid>
                    {summary.map((metric) => (
                        <Metric key={metric.label}>
                            <MetricLabel>{metric.label}</MetricLabel>
                            <MetricValue>{metric.value}</MetricValue>
                        </Metric>
                    ))}
                </SummaryGrid>
            </SummaryCard>

            <FilterBar fields={filterFields} />

            <SectionTitle>Муниципальные округа и налогоплательщики</SectionTitle>

            <TableWrap>
                <Table>
                    <thead>
                    <tr>
                        <HeadCell style={{ width: '44px' }} />
                        <HeadCell style={{ width: '110px' }}>ОКТМО</HeadCell>
                        <HeadCell style={{ width: '180px' }}>Наименование МО</HeadCell>
                        <HeadCell style={{ width: '140px' }}>Общее кол-во предприятий</HeadCell>
                        <HeadCell style={{ width: '135px' }}>Количество сотрудников</HeadCell>
                        <HeadCell style={{ width: '130px' }}>Количество должников</HeadCell>
                        <HeadCell style={{ width: '170px' }}>
                            Доля должников к общему количеству сотрудников
                        </HeadCell>
                        <HeadCell style={{ width: '170px' }}>Общая сумма задолженности по сотрудникам</HeadCell>
                        <HeadCell style={{ width: '90px' }}>Рейтинг</HeadCell>
                    </tr>
                    </thead>

                    <tbody>
                    {!moTableData.length ? (
                        <tr>
                            <Cell colSpan={9}>
                                <EmptyState>Нет данных по выбранным параметрам</EmptyState>
                            </Cell>
                        </tr>
                    ) : (
                        moTableData.map((row) => {
                            const nestedRows = (taxpayersByOktmo.get(row.oktmo) ?? []).filter((item) => {
                                if (filters.budgetType === 'budget') return item.isBudgetOrganization;
                                if (filters.budgetType === 'non-budget') return !item.isBudgetOrganization;
                                return true;
                            });

                            const isExpanded = expandedOktmo === row.oktmo;

                            return (
                                <>
                                    <MoRow key={`mo-${row.oktmo}-${row.budgetType}`}>
                                        <Cell $align="center">
                                            <ExpandButton type="button" onClick={() => handleToggleMo(row.oktmo)}>
                                                {isExpanded ? '−' : '+'}
                                            </ExpandButton>
                                        </Cell>
                                        <Cell>{row.oktmo}</Cell>
                                        <Cell>{row.moName}</Cell>
                                        <Cell $align="center">{row.enterprisesCount.toLocaleString('ru-RU')}</Cell>
                                        <Cell $align="center">{row.employeesCount.toLocaleString('ru-RU')}</Cell>
                                        <Cell $align="center">{row.debtorsCount.toLocaleString('ru-RU')}</Cell>
                                        <Cell $align="center">{formatPercent(row.employeesCount, row.debtorsCount)}</Cell>
                                        <Cell $align="right">{formatAmount(row.debtAmount)}</Cell>
                                        <Cell $align="center">{row.rating}</Cell>
                                    </MoRow>

                                    {isExpanded ? (
                                        <ExpandedRow key={`expanded-${row.oktmo}-${row.budgetType}`}>
                                            <ExpandedCell colSpan={9}>
                                                <NestedWrap>
                                                    <NestedTop>
                                                        <NestedHeader>Налогоплательщики внутри МО</NestedHeader>

                                                        <NestedActions>
                                                            <SmallActionButton
                                                                type="button"
                                                                onClick={() => exportMoStatisticsXlsx(row, nestedRows)}
                                                            >
                                                                Скачать статистику по выбранному МО
                                                            </SmallActionButton>

                                                            <SmallActionButton
                                                                type="button"
                                                                onClick={() => exportMoDetailsXlsx(row, nestedRows)}
                                                            >
                                                                Скачать детализацию по выбранному МО
                                                            </SmallActionButton>
                                                        </NestedActions>
                                                    </NestedTop>

                                                    {!nestedRows.length ? (
                                                        <EmptyState>Нет плательщиков по выбранным параметрам</EmptyState>
                                                    ) : (
                                                        <NestedTable>
                                                            <thead>
                                                            <tr>
                                                                <NestedHeadCell>ИНН</NestedHeadCell>
                                                                <NestedHeadCell>Наименование</NestedHeadCell>
                                                                <NestedHeadCell>Общая сумма задолженности по сотрудникам</NestedHeadCell>
                                                                <NestedHeadCell>Количество сотрудников</NestedHeadCell>
                                                                <NestedHeadCell>Количество должников</NestedHeadCell>
                                                                <NestedHeadCell>Доля должников</NestedHeadCell>
                                                                <NestedHeadCell>Сотрудники</NestedHeadCell>
                                                                <NestedHeadCell>БО</NestedHeadCell>
                                                                <NestedHeadCell>ФССП</NestedHeadCell>
                                                            </tr>
                                                            </thead>
                                                            <tbody>
                                                            {nestedRows.map((taxpayer) => (
                                                                <tr key={taxpayer.inn}>
                                                                    <NestedCell>
                                                                        <LinkButton
                                                                            type="button"
                                                                            onClick={() => {
                                                                                const card = secondLevelDebtCardsByInn[taxpayer.inn];
                                                                                if (card) dispatch(openDebtCard(card));
                                                                            }}
                                                                        >
                                                                            {taxpayer.inn}
                                                                        </LinkButton>
                                                                    </NestedCell>
                                                                    <NestedCell>
                                                                        <BudgetName $budget={taxpayer.isBudgetOrganization}>
                                                                            {taxpayer.name}
                                                                        </BudgetName>
                                                                    </NestedCell>
                                                                    <NestedCell>{formatAmount(taxpayer.debtAmount)}</NestedCell>
                                                                    <NestedCell>{taxpayer.employeesCount.toLocaleString('ru-RU')}</NestedCell>
                                                                    <NestedCell>{taxpayer.debtorsCount.toLocaleString('ru-RU')}</NestedCell>
                                                                    <NestedCell>
                                                                        {formatPercent(taxpayer.employeesCount, taxpayer.debtorsCount)}
                                                                    </NestedCell>
                                                                    <NestedCell>
                                                                        <EmployeeButton
                                                                            type="button"
                                                                            onClick={() =>
                                                                                exportTaxpayerEmployeesXlsx(
                                                                                    taxpayer,
                                                                                    taxpayer.employees ?? [],
                                                                                )
                                                                            }
                                                                        >
                                                                            Скачать
                                                                        </EmployeeButton>
                                                                    </NestedCell>
                                                                    <NestedCell>
                                                                        <TaxpayerTypeBadge $budget={taxpayer.isBudgetOrganization}>
                                                                            {taxpayer.isBudgetOrganization ? 'БО' : '—'}
                                                                        </TaxpayerTypeBadge>
                                                                    </NestedCell>
                                                                    <NestedCell>
                                                                        <FsspBadge $active={taxpayer.hasFssp}>
                                                                            {taxpayer.hasFssp ? 'Есть' : '—'}
                                                                        </FsspBadge>
                                                                    </NestedCell>
                                                                </tr>
                                                            ))}
                                                            </tbody>
                                                        </NestedTable>
                                                    )}
                                                </NestedWrap>
                                            </ExpandedCell>
                                        </ExpandedRow>
                                    ) : null}
                                </>
                            );
                        })
                    )}
                    </tbody>
                </Table>
            </TableWrap>

            <DebtCardModal
                open={isCardOpen}
                card={selectedCard}
                onClose={() => dispatch(closeDebtCard())}
            />
        </>
    );
}