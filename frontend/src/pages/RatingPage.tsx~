import { Fragment, useEffect, useMemo } from 'react';
import styled from 'styled-components';
import { useAppDispatch, useAppSelector } from '../app/hooks';
import { FilterBar, type FilterField } from '../components/common/FilterBar';
import { PageHeader } from '../components/common/PageHeader';
import { SummaryGrid } from '../components/common/SummaryGrid';
import {
    ratingMoRows,
    ratingRegionRows,
    ratingSummaryByRegion,
    topBestMoRows,
    topBudgetDebtorsRows,
    topDebtorsRows,
    topSecondLevelDebtorsRows,
    topWorstMoRows,
} from '../features/rating/mockData';
import {
    setRatingFilters,
    setRatingMoRows,
    setRatingRegionRows,
    setRatingSummary,
    setRatingTopBestMoRows,
    setRatingTopWorstMoRows,
    setTopBudgetDebtorsRows,
    setTopDebtorsRows,
    setTopSecondLevelDebtorsRows,
} from '../features/rating/ratingSlice';
import type {
    RatingMoRow,
    RatingRegionRow,
    RatingTopDebtorRow,
    RatingTopDebtorSecondLevelRow,
    RatingTopMoRow,
} from '../types/rating';

const Section = styled.section`
  margin-top: 22px;
`;

const SectionTitle = styled.h3`
  margin: 0 0 12px;
  font-size: 18px;
`;

const TwinGrid = styled.div`
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;

  @media (max-width: 980px) {
    grid-template-columns: 1fr;
  }
`;

const TableWrap = styled.div`
  width: 100%;
  overflow-x: auto;
  border: 1px solid ${({ theme }) => theme.colors.border};
  border-radius: 18px;
  background: ${({ theme }) => theme.colors.surface};
`;

const Table = styled.table`
  width: 100%;
  border-collapse: collapse;
  min-width: 1880px;
`;

const CompactTable = styled.table`
  width: 100%;
  border-collapse: collapse;
  min-width: 100%;
`;

const HeadCell = styled.th`
  padding: 10px 8px;
  font-size: 12px;
  font-weight: 700;
  text-align: center;
  color: ${({ theme }) => theme.colors.text};
  background: ${({ theme }) => theme.colors.surfaceAlt};
  border-bottom: 1px solid ${({ theme }) => theme.colors.border};
`;

const Cell = styled.td<{ $align?: 'left' | 'center' | 'right' }>`
  padding: 10px 8px;
  font-size: 12px;
  text-align: ${({ $align = 'left' }) => $align};
  border-bottom: 1px solid ${({ theme }) => theme.colors.border};
  vertical-align: middle;
`;

const formatAmount = (value: number) => `${value.toLocaleString('ru-RU')} ₽`;

export function RatingPage() {
    const dispatch = useAppDispatch();
    const {
        summary,
        regionRows,
        moRows,
        topBestMoRows: bestRows,
        topWorstMoRows: worstRows,
        topDebtorsRows: debtorsRows,
        topBudgetDebtorsRows: budgetDebtorsRows,
        topSecondLevelDebtorsRows: secondLevelRows,
        filters,
    } = useAppSelector((state) => state.rating);
    const { isAdmin, region: userRegion } = useAppSelector((state) => state.auth);

    useEffect(() => {
        dispatch(setRatingRegionRows(ratingRegionRows));
        dispatch(setRatingMoRows(ratingMoRows));
        dispatch(setRatingTopBestMoRows(topBestMoRows));
        dispatch(setRatingTopWorstMoRows(topWorstMoRows));
        dispatch(setTopDebtorsRows(topDebtorsRows));
        dispatch(setTopBudgetDebtorsRows(topBudgetDebtorsRows));
        dispatch(setTopSecondLevelDebtorsRows(topSecondLevelDebtorsRows));
    }, [dispatch]);

    useEffect(() => {
        const activeRegion = isAdmin ? filters.region || 'all' : userRegion || 'all';
        dispatch(setRatingSummary(ratingSummaryByRegion[activeRegion] ?? ratingSummaryByRegion.all));
    }, [dispatch, filters.region, isAdmin, userRegion]);

    const visibleMoRows = useMemo(() => {
        const activeRegion = isAdmin ? filters.region : userRegion ?? '';

        return moRows.filter((row) => {
            const regionMatches = !activeRegion || row.region === activeRegion;
            const periodMatches = !filters.period || row.period === filters.period;
            return regionMatches && periodMatches;
        });
    }, [filters.period, filters.region, isAdmin, moRows, userRegion]);

    const filterFields: FilterField[] = [
        ...(isAdmin
            ? [
                {
                    key: 'region',
                    label: 'Регион',
                    type: 'select' as const,
                    value: filters.region,
                    options: [
                        { value: '', label: 'Все регионы' },
                        { value: '77', label: '77 — Москва' },
                        { value: '78', label: '78 — Санкт-Петербург' },
                        { value: '50', label: '50 — Московская область' },
                    ],
                    onChange: (value: string) => dispatch(setRatingFilters({ region: value })),
                },
            ]
            : []),
        {
            key: 'period',
            label: 'Период',
            type: 'select' as const,
            value: filters.period,
            options: [
                { value: '2026-Q1', label: '2026 Q1' },
                { value: '2025-Q4', label: '2025 Q4' },
            ],
            onChange: (value: string) => dispatch(setRatingFilters({ period: value })),
        },
    ];

    return (
        <>
            <PageHeader
                title="Рейтинг МО"
                description="Структура таблиц и заголовков сохранена по образцу старого сервиса, обновлён только визуальный слой."
            />

            <SummaryGrid metrics={summary} />

            <FilterBar fields={filterFields} />

            <Section>
                <SectionTitle>Рейтинг по ОКТМО</SectionTitle>
                <TableWrap>
                    <Table>
                        <thead>
                        <tr>
                            <HeadCell rowSpan={2}>№</HeadCell>
                            <HeadCell rowSpan={2}>ОКТМО</HeadCell>
                            <HeadCell rowSpan={2}>Наименование МО</HeadCell>

                            <HeadCell colSpan={2}>Соотношение долга к поступлениям (DTI)</HeadCell>
                            <HeadCell colSpan={2}>Доля должников БО</HeadCell>
                            <HeadCell colSpan={2}>Доля должников в общем количестве НП</HeadCell>
                            <HeadCell colSpan={2}>Доля НП, имеющих переплату</HeadCell>
                            <HeadCell colSpan={2}>
                                Доля НП БО, имеющих переплату, в общем количестве НП БО
                            </HeadCell>
                            <HeadCell colSpan={2}>Динамика долга за 12 месяцев</HeadCell>
                            <HeadCell colSpan={2}>Динамика долга БО за 12 месяцев</HeadCell>
                            <HeadCell colSpan={2}>
                                Доля должников к сотрудникам организаций с численностью &gt;100
                            </HeadCell>
                            <HeadCell colSpan={2}>
                                Доля должников к сотрудникам организаций БО с численностью &gt;100
                            </HeadCell>
                            <HeadCell colSpan={2}>Доля комиссий</HeadCell>

                            <HeadCell rowSpan={2}>Рейтинг МО</HeadCell>
                        </tr>

                        <tr>
                            {Array.from({ length: 10 }).map((_, index) => (
                                <Fragment key={index}>
                                    <HeadCell>Значение</HeadCell>
                                    <HeadCell>Место</HeadCell>
                                </Fragment>
                            ))}
                        </tr>
                        </thead>

                        <tbody>
                        {!visibleMoRows.length ? (
                            <tr>
                                <Cell colSpan={24} $align="center">
                                    Нет данных по выбранным параметрам
                                </Cell>
                            </tr>
                        ) : (
                            visibleMoRows.map((row: RatingMoRow) => (
                                <tr key={row.id}>
                                    <Cell $align="center">{row.id}</Cell>
                                    <Cell>{row.oktmo}</Cell>
                                    <Cell>{row.moName}</Cell>

                                    <Cell $align="center">{row.dti.value}</Cell>
                                    <Cell $align="center">{row.dti.place}</Cell>

                                    <Cell $align="center">{row.debtorsBudgetShare.value}</Cell>
                                    <Cell $align="center">{row.debtorsBudgetShare.place}</Cell>

                                    <Cell $align="center">{row.debtorsNpShare.value}</Cell>
                                    <Cell $align="center">{row.debtorsNpShare.place}</Cell>

                                    <Cell $align="center">{row.overpaymentNpShare.value}</Cell>
                                    <Cell $align="center">{row.overpaymentNpShare.place}</Cell>

                                    <Cell $align="center">{row.overpaymentBudgetNpShare.value}</Cell>
                                    <Cell $align="center">{row.overpaymentBudgetNpShare.place}</Cell>

                                    <Cell $align="center">{row.debt12mDynamics.value}</Cell>
                                    <Cell $align="center">{row.debt12mDynamics.place}</Cell>

                                    <Cell $align="center">{row.budgetDebt12mDynamics.value}</Cell>
                                    <Cell $align="center">{row.budgetDebt12mDynamics.place}</Cell>

                                    <Cell $align="center">{row.debtorsToEmployeesOver100.value}</Cell>
                                    <Cell $align="center">{row.debtorsToEmployeesOver100.place}</Cell>

                                    <Cell $align="center">{row.budgetDebtorsToEmployeesOver100.value}</Cell>
                                    <Cell $align="center">{row.budgetDebtorsToEmployeesOver100.place}</Cell>

                                    <Cell $align="center">{row.commissionsShare.value}</Cell>
                                    <Cell $align="center">{row.commissionsShare.place}</Cell>

                                    <Cell $align="center">{row.finalRating}</Cell>
                                </tr>
                            ))
                        )}
                        </tbody>
                    </Table>
                </TableWrap>
            </Section>

            <Section>
                <SectionTitle>Рейтинг по региону</SectionTitle>
                <TableWrap>
                    <CompactTable>
                        <thead>
                        <tr>
                            <HeadCell>№</HeadCell>
                            <HeadCell>Показатель</HeadCell>
                            <HeadCell>Место в рейтинге</HeadCell>
                            <HeadCell>Значение показателя</HeadCell>
                            <HeadCell>Среднее значение по РФ</HeadCell>
                            <HeadCell>Передовая практика</HeadCell>
                        </tr>
                        </thead>
                        <tbody>
                        {regionRows.map((row: RatingRegionRow) => (
                            <tr key={row.id}>
                                <Cell $align="center">{row.id}</Cell>
                                <Cell>{row.name}</Cell>
                                <Cell $align="center">{row.place}</Cell>
                                <Cell $align="center">{row.value}</Cell>
                                <Cell $align="center">{row.averageRf}</Cell>
                                <Cell>{row.bestPractice ?? '—'}</Cell>
                            </tr>
                        ))}
                        </tbody>
                    </CompactTable>
                </TableWrap>
            </Section>

            <Section>
                <TwinGrid>
                    <div>
                        <SectionTitle>Топ-5 муниципальных образований по наивысшему рейтингу</SectionTitle>
                        <TableWrap>
                            <CompactTable>
                                <thead>
                                <tr>
                                    <HeadCell>ОКТМО</HeadCell>
                                    <HeadCell>Наименование МО</HeadCell>
                                    <HeadCell>Рейтинг</HeadCell>
                                </tr>
                                </thead>
                                <tbody>
                                {bestRows.map((row: RatingTopMoRow) => (
                                    <tr key={`${row.oktmo}-${row.moName}`}>
                                        <Cell>{row.oktmo}</Cell>
                                        <Cell>{row.moName}</Cell>
                                        <Cell $align="center">{row.rating}</Cell>
                                    </tr>
                                ))}
                                </tbody>
                            </CompactTable>
                        </TableWrap>
                    </div>

                    <div>
                        <SectionTitle>Топ-5 муниципальных образований по наименьшему рейтингу</SectionTitle>
                        <TableWrap>
                            <CompactTable>
                                <thead>
                                <tr>
                                    <HeadCell>ОКТМО</HeadCell>
                                    <HeadCell>Наименование МО</HeadCell>
                                    <HeadCell>Рейтинг</HeadCell>
                                </tr>
                                </thead>
                                <tbody>
                                {worstRows.map((row: RatingTopMoRow) => (
                                    <tr key={`${row.oktmo}-${row.moName}`}>
                                        <Cell>{row.oktmo}</Cell>
                                        <Cell>{row.moName}</Cell>
                                        <Cell $align="center">{row.rating}</Cell>
                                    </tr>
                                ))}
                                </tbody>
                            </CompactTable>
                        </TableWrap>
                    </div>
                </TwinGrid>
            </Section>

            <Section>
                <TwinGrid>
                    <div>
                        <SectionTitle>Топ должников</SectionTitle>
                        <TableWrap>
                            <CompactTable>
                                <thead>
                                <tr>
                                    <HeadCell>Место</HeadCell>
                                    <HeadCell>ОКТМО</HeadCell>
                                    <HeadCell>Наименование НП</HeadCell>
                                    <HeadCell>Сумма долга, тыс.руб.</HeadCell>
                                </tr>
                                </thead>
                                <tbody>
                                {debtorsRows.map((row: RatingTopDebtorRow) => (
                                    <tr key={`${row.place}-${row.name}`}>
                                        <Cell $align="center">{row.place}</Cell>
                                        <Cell>{row.oktmo}</Cell>
                                        <Cell>{row.name}</Cell>
                                        <Cell $align="right">{formatAmount(row.debtAmount)}</Cell>
                                    </tr>
                                ))}
                                </tbody>
                            </CompactTable>
                        </TableWrap>
                    </div>

                    <div>
                        <SectionTitle>Топ должников бюджетных организаций</SectionTitle>
                        <TableWrap>
                            <CompactTable>
                                <thead>
                                <tr>
                                    <HeadCell>Место</HeadCell>
                                    <HeadCell>ОКТМО</HeadCell>
                                    <HeadCell>Наименование НП</HeadCell>
                                    <HeadCell>Сумма долга, тыс.руб.</HeadCell>
                                </tr>
                                </thead>
                                <tbody>
                                {budgetDebtorsRows.map((row: RatingTopDebtorRow) => (
                                    <tr key={`${row.place}-${row.name}`}>
                                        <Cell $align="center">{row.place}</Cell>
                                        <Cell>{row.oktmo}</Cell>
                                        <Cell>{row.name}</Cell>
                                        <Cell $align="right">{formatAmount(row.debtAmount)}</Cell>
                                    </tr>
                                ))}
                                </tbody>
                            </CompactTable>
                        </TableWrap>
                    </div>
                </TwinGrid>
            </Section>

            <Section>
                <SectionTitle>Топ должников 2-го уровня</SectionTitle>
                <TableWrap>
                    <CompactTable>
                        <thead>
                        <tr>
                            <HeadCell>Место</HeadCell>
                            <HeadCell>ОКТМО</HeadCell>
                            <HeadCell>Наименование НП</HeadCell>
                            <HeadCell>Доля должников</HeadCell>
                            <HeadCell>Сумма долга, тыс.руб.</HeadCell>
                        </tr>
                        </thead>
                        <tbody>
                        {secondLevelRows.map((row: RatingTopDebtorSecondLevelRow) => (
                            <tr key={`${row.place}-${row.name}`}>
                                <Cell $align="center">{row.place}</Cell>
                                <Cell>{row.oktmo}</Cell>
                                <Cell>{row.name}</Cell>
                                <Cell $align="center">{row.debtorsShare}</Cell>
                                <Cell $align="right">{formatAmount(row.debtAmount)}</Cell>
                            </tr>
                        ))}
                        </tbody>
                    </CompactTable>
                </TableWrap>
            </Section>
        </>
    );
}