import { createSlice, type PayloadAction } from '@reduxjs/toolkit';
import type {
    FeedbackAttachment,
    FeedbackDraftTemplate,
    FeedbackMessage,
    FeedbackTicket,
    TicketStatus,
} from '../../types/feedback';
import { feedbackTemplateInitial } from './mockData';

type FeedbackState = {
    tickets: FeedbackTicket[];
    messages: FeedbackMessage[];
    selectedTicketId: string | null;
    statusFilter: 'all' | TicketStatus;
    isCreateModalOpen: boolean;
    draftTemplate: FeedbackDraftTemplate;
    replyText: string;
    isLoadingTickets: boolean;
    isLoadingMessages: boolean;
    isSubmitting: boolean;
    error: string;
};

const initialState: FeedbackState = {
    tickets: [],
    messages: [],
    selectedTicketId: null,
    statusFilter: 'all',
    isCreateModalOpen: false,
    draftTemplate: feedbackTemplateInitial,
    replyText: '',
    isLoadingTickets: false,
    isLoadingMessages: false,
    isSubmitting: false,
    error: '',
};

const isFinalStatus = (status: TicketStatus) => status === 'resolved' || status === 'closed';

const feedbackSlice = createSlice({
    name: 'feedback',
    initialState,
    reducers: {
        setFeedbackStatusFilter(state, action: PayloadAction<'all' | TicketStatus>) {
            state.statusFilter = action.payload;
        },

        selectFeedbackTicket(state, action: PayloadAction<string>) {
            state.selectedTicketId = action.payload;
        },

        openCreateFeedbackModal(state) {
            state.isCreateModalOpen = true;
        },

        closeCreateFeedbackModal(state) {
            state.isCreateModalOpen = false;
            state.draftTemplate = feedbackTemplateInitial;
        },

        updateFeedbackDraft(state, action: PayloadAction<Partial<FeedbackDraftTemplate>>) {
            state.draftTemplate = {
                ...state.draftTemplate,
                ...action.payload,
            };
        },

        setFeedbackDraftAttachment(state, action: PayloadAction<FeedbackAttachment | null>) {
            state.draftTemplate.attachment = action.payload;
        },

        setFeedbackReplyText(state, action: PayloadAction<string>) {
            state.replyText = action.payload;
        },

        setFeedbackTicketsLoading(state, action: PayloadAction<boolean>) {
            state.isLoadingTickets = action.payload;
        },

        setFeedbackMessagesLoading(state, action: PayloadAction<boolean>) {
            state.isLoadingMessages = action.payload;
        },

        setFeedbackSubmitting(state, action: PayloadAction<boolean>) {
            state.isSubmitting = action.payload;
        },

        setFeedbackError(state, action: PayloadAction<string>) {
            state.error = action.payload;
        },

        setFeedbackTickets(state, action: PayloadAction<FeedbackTicket[]>) {
            state.tickets = action.payload;

            if (!state.selectedTicketId && action.payload.length) {
                state.selectedTicketId = action.payload[0].id;
            }

            if (
                state.selectedTicketId &&
                !action.payload.find((ticket) => ticket.id === state.selectedTicketId)
            ) {
                state.selectedTicketId = action.payload[0]?.id ?? null;
            }
        },

        setFeedbackMessages(state, action: PayloadAction<FeedbackMessage[]>) {
            state.messages = action.payload;
        },

        createFeedbackTicketSuccess(
            state,
            action: PayloadAction<{
                ticketId: string;
            }>,
        ) {
            state.selectedTicketId = action.payload.ticketId;
            state.isCreateModalOpen = false;
            state.draftTemplate = feedbackTemplateInitial;
        },

        sendFeedbackReplySuccess(state) {
            state.replyText = '';
        },

        updateFeedbackTicketStatusLocal(
            state,
            action: PayloadAction<{
                ticketId: string;
                status: TicketStatus;
            }>,
        ) {
            state.tickets = state.tickets.map((ticket) => {
                if (ticket.id !== action.payload.ticketId) return ticket;
                if (isFinalStatus(ticket.status)) return ticket;

                return {
                    ...ticket,
                    status: action.payload.status,
                };
            });
        },
    },
});

export const {
    setFeedbackStatusFilter,
    selectFeedbackTicket,
    openCreateFeedbackModal,
    closeCreateFeedbackModal,
    updateFeedbackDraft,
    setFeedbackDraftAttachment,
    setFeedbackReplyText,
    setFeedbackTicketsLoading,
    setFeedbackMessagesLoading,
    setFeedbackSubmitting,
    setFeedbackError,
    setFeedbackTickets,
    setFeedbackMessages,
    createFeedbackTicketSuccess,
    sendFeedbackReplySuccess,
    updateFeedbackTicketStatusLocal,
} = feedbackSlice.actions;

export default feedbackSlice.reducer;